<div class="container mt-4">
    <h4 class="mb-4" style="color: var(--marron-oscuro);">
        <i class="fas fa-edit me-2"></i>Editar Tipo de Comercio
    </h4>

    <div class="tarjeta" style="max-width: 500px;">
        {{> mensajes}}
        <form action="/admin/tipos-comercio/{{tipo._id}}/editar" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label etiqueta">Nombre</label>
                <input type="text" name="nombre" class="form-control campo-input"
                    value="{{tipo.nombre}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Descripción</label>
                <input type="text" name="descripcion" class="form-control campo-input"
                    value="{{tipo.descripcion}}" required>
            </div>
            {{#if tipo.icono}}
            <div class="mb-2">
                <p class="etiqueta mb-1">Icono actual:</p>
                <img src="/uploads/{{tipo.icono}}" style="width:60px;height:60px;object-fit:cover;border-radius:8px;">
            </div>
            {{/if}}
            <div class="mb-4">
                <label class="form-label etiqueta">Cambiar icono <span class="texto-opcional">(opcional)</span></label>
                <input type="file" name="icono" class="form-control campo-input" accept="image/*">
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/tipos-comercio" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>