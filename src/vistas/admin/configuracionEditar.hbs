<div class="container mt-4">
    <h4 class="mb-4" style="color: var(--marron-oscuro);">
        <i class="fas fa-edit me-2"></i>Editar Configuración
    </h4>

    <div class="tarjeta" style="max-width: 500px;">
        {{> mensajes}}
        <form action="/admin/configuracion/editar" method="POST">
            <div class="mb-4">
                <label class="form-label etiqueta">ITBIS (%)</label>
                <input type="number" name="valor" class="form-control campo-input"
                    value="{{config.valor}}" min="0" max="100" step="0.01" required>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/configuracion" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>