<div class="container mt-4">
    <h4 class="mb-4" style="color: var(--marron-oscuro);">
        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
    </h4>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="tarjeta text-center">
                <i class="fas fa-box fa-2x mb-2" style="color: var(--marron-medio);"></i>
                <h3 class="fw-bold">{{totalPedidos}}</h3>
                <p class="text-muted mb-0">Total de pedidos</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="tarjeta text-center">
                <i class="fas fa-calendar-day fa-2x mb-2" style="color: var(--marron-medio);"></i>
                <h3 class="fw-bold">{{pedidosHoy}}</h3>
                <p class="text-muted mb-0">Pedidos hoy</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="tarjeta text-center">
                <i class="fas fa-box-open fa-2x mb-2" style="color: var(--marron-medio);"></i>
                <h3 class="fw-bold">{{totalProductos}}</h3>
                <p class="text-muted mb-0">Productos creados</p>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="tarjeta">
                <h6 class="fw-bold mb-3"><i class="fas fa-store me-2"></i>Comercios</h6>
                <div class="d-flex justify-content-between">
                    <span class="badge bg-success px-3 py-2">Activos: {{comerciosActivos}}</span>
                    <span class="badge bg-secondary px-3 py-2">Inactivos: {{comerciosInactivos}}</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tarjeta">
                <h6 class="fw-bold mb-3"><i class="fas fa-users me-2"></i>Clientes</h6>
                <div class="d-flex justify-content-between">
                    <span class="badge bg-success px-3 py-2">Activos: {{clientesActivos}}</span>
                    <span class="badge bg-secondary px-3 py-2">Inactivos: {{clientesInactivos}}</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tarjeta">
                <h6 class="fw-bold mb-3"><i class="fas fa-motorcycle me-2"></i>Deliveries</h6>
                <div class="d-flex justify-content-between">
                    <span class="badge bg-success px-3 py-2">Activos: {{deliveriesActivos}}</span>
                    <span class="badge bg-secondary px-3 py-2">Inactivos: {{deliveriesInactivos}}</span>
                </div>
            </div>
        </div>
    </div>
</div>