<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color: var(--marron-oscuro);">
            <i class="fas fa-tags me-2"></i>Tipos de Comercio
        </h4>
        <a href="/admin/tipos-comercio/crear" class="btn boton-principal">
            <i class="fas fa-plus me-2"></i>Nuevo tipo
        </a>
    </div>

    <div class="tarjeta">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead style="background-color: var(--crema-oscuro);">
                    <tr>
                        <th>Icono</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Comercios</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each tipos}}
                    <tr>
                        <td>
                            {{#if icono}}
                                <img src="/uploads/{{icono}}" alt="icono" style="width:40px;height:40px;object-fit:cover;border-radius:8px;">
                            {{else}}
                                <i class="fas fa-store" style="color:var(--marron-medio);font-size:1.5rem;"></i>
                            {{/if}}
                        </td>
                        <td>{{nombre}}</td>
                        <td>{{descripcion}}</td>
                        <td>{{cantidad}}</td>
                        <td>
                            <a href="/admin/tipos-comercio/{{_id}}/editar" class="btn btn-sm boton-secundario me-1">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a href="/admin/tipos-comercio/{{_id}}/eliminar" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No hay tipos de comercio creados aún.</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>