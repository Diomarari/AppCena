<div class="container mt-4">
    <h4 class="mb-4" style="color: var(--marron-oscuro);">
        <i class="fas fa-user-edit me-2"></i>Editar Administrador
    </h4>

    <div class="tarjeta" style="max-width: 600px;">
        {{> mensajes}}
        <form action="/admin/administradores/{{admin._id}}/editar" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Nombre</label>
                    <input type="text" name="nombre" class="form-control campo-input"
                        value="{{admin.nombre}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Apellido</label>
                    <input type="text" name="apellido" class="form-control campo-input"
                        value="{{admin.apellido}}" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Cédula</label>
                    <input type="text" name="cedula" class="form-control campo-input"
                        value="{{admin.cedula}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Correo</label>
                    <input type="email" name="correo" class="form-control campo-input"
                        value="{{admin.correo}}" required>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Nombre de usuario</label>
                <input type="text" name="nombreUsuario" class="form-control campo-input"
                    value="{{admin.nombreUsuario}}" required>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Nueva contraseña <span class="texto-opcional">(opcional)</span></label>
                    <input type="password" name="contrasena" class="form-control campo-input">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Confirmar contraseña</label>
                    <input type="password" name="confirmarContrasena" class="form-control campo-input">
                </div>
            </div>
            <div class="d-flex gap-2 mt-2">
                <a href="/admin/administradores" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>