<div class="container mt-4" style="max-width:600px;margin:auto;">
    <div class="text-center mb-4">
        {{#if pedido.comercio.logo}}
            <img src="/uploads/{{pedido.comercio.logo}}"
                style="width:60px;height:60px;border-radius:50%;object-fit:cover;">
        {{/if}}
        <h5 class="fw-bold mt-2" style="color:var(--marron-oscuro);">
            {{pedido.comercio.nombreComercio}}
        </h5>
        <span class="badge fs-6 {{#if (eq pedido.estado 'en proceso')}}badge-proceso{{else}}badge-completado{{/if}}">
            {{pedido.estado}}
        </span>
        <p class="text-muted small mt-1">{{formatFecha pedido.fechaPedido}}</p>
    </div>

    {{#if puedeCompletar}}
    <form action="/delivery/pedidos/{{pedido._id}}/completar" method="POST" class="mb-3">
        <button type="submit" class="btn boton-principal w-100"
            onclick="return confirm('¿Confirmas que entregaste este pedido?')">
            <i class="fas fa-check-circle me-2"></i>Completar el pedido
        </button>
    </form>
    {{/if}}

    <div class="tarjeta mb-3">
        <h6 class="fw-bold mb-3">El pedido</h6>
        {{#each detalles}}
        <div class="d-flex align-items-center mb-3">
            {{#if foto}}
                <img src="/uploads/{{foto}}"
                    style="width:50px;height:50px;object-fit:cover;border-radius:8px;margin-right:12px;">
            {{else}}
                <div style="width:50px;height:50px;background:var(--crema-oscuro);border-radius:8px;margin-right:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-utensils" style="color:var(--marron-medio);"></i>
                </div>
            {{/if}}
            <div class="flex-grow-1">
                <p class="fw-bold mb-0 small">{{nombreProducto}}</p>
            </div>
            <span class="fw-bold" style="color:var(--marron-medio);">RD$ {{precio}}</span>
        </div>
        {{/each}}

        {{#if mostrarDireccion}}
        <hr>
        <div class="d-flex align-items-start mt-2">
            <i class="fas fa-map-marker-alt me-2 mt-1" style="color:var(--marron-medio);"></i>
            <div>
                <p class="etiqueta mb-0">Dirección</p>
                <p class="fw-bold mb-0">{{pedido.direccion.nombre}}</p>
                <p class="text-muted small">{{pedido.direccion.descripcion}}</p>
            </div>
        </div>
        {{/if}}

        <hr>
        <div class="d-flex justify-content-between fw-bold">
            <span>Total</span>
            <span style="color:var(--marron-medio);">RD$ {{pedido.total}}</span>
        </div>
    </div>

    <a href="/delivery/home" class="btn boton-secundario">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>