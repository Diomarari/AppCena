<div class="pagina-auth">
    <div class="tarjeta-auth tarjeta-grande">
        <div class="texto-centro mb-4">
            <i class="fas fa-user-plus icono-grande"></i>
            <h2 class="titulo-auth">Crear cuenta</h2>
            <p class="subtitulo-auth">¡Únete a AppCenar y empieza a pedir!</p>
        </div>

        {{> mensajes}}

        <form action="/registro" method="POST" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Nombre</label>
                    <input type="text" name="nombre" class="form-control campo-input"
                        placeholder="Tu nombre" value="{{datos.nombre}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Apellido</label>
                    <input type="text" name="apellido" class="form-control campo-input"
                        placeholder="Tu apellido" value="{{datos.apellido}}" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Teléfono</label>
                    <input type="text" name="telefono" class="form-control campo-input"
                        placeholder="809-000-0000" value="{{datos.telefono}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Correo electrónico</label>
                    <input type="email" name="correo" class="form-control campo-input"
                        placeholder="tucorreo@ejemplo.com" value="{{datos.correo}}" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Nombre de usuario</label>
                    <input type="text" name="nombreUsuario" class="form-control campo-input"
                        placeholder="usuario123" value="{{datos.nombreUsuario}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Quiero registrarme como</label>
                    <select name="rol" class="form-select campo-input" required>
                        <option value="">Selecciona un rol...</option>
                        <option value="cliente" {{#if (eq datos.rol 'cliente')}}selected{{/if}}>Cliente</option>
                        <option value="delivery" {{#if (eq datos.rol 'delivery')}}selected{{/if}}>Delivery</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Foto de perfil <span class="texto-opcional">(opcional)</span></label>
                <input type="file" name="foto" class="form-control campo-input" accept="image/*">
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Contraseña</label>
                    <input type="password" name="contrasena" class="form-control campo-input"
                        placeholder="••••••••" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Confirmar contraseña</label>
                    <input type="password" name="confirmarContrasena" class="form-control campo-input"
                        placeholder="••••••••" required>
                </div>
            </div>
            <button type="submit" class="btn boton-principal w-100 mb-3">
                <i class="fas fa-check me-2"></i>Crear mi cuenta
            </button>
            <a href="/" class="btn boton-texto w-100">
                <i class="fas fa-arrow-left me-2"></i>Volver al inicio de sesión
            </a>
        </form>
    </div>
</div>