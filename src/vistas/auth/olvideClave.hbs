<div class="pagina-auth">
    <div class="tarjeta-auth">
        <div class="texto-centro mb-4">
            <i class="fas fa-lock icono-grande"></i>
            <h2 class="titulo-auth">Restablecer contraseña</h2>
            <p class="subtitulo-auth">Ingresa tu correo o usuario y te enviamos un enlace.</p>
        </div>

        {{> mensajes}}

        <form action="/olvide-clave" method="POST">
            <div class="mb-4">
                <label class="form-label etiqueta">Correo o nombre de usuario</label>
                <input type="text" name="identificador" class="form-control campo-input"
                    placeholder="tucorreo@ejemplo.com" required>
            </div>
            <button type="submit" class="btn boton-principal w-100 mb-3">
                <i class="fas fa-paper-plane me-2"></i>Enviar enlace
            </button>
            <a href="/" class="btn boton-texto w-100">
                <i class="fas fa-arrow-left me-2"></i>Volver al inicio de sesión
            </a>
        </form>
    </div>
</div>