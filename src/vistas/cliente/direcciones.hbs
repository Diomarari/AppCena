<div class="container mt-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 style="color: var(--marron-oscuro);">
            <i class="fas fa-map-marker-alt me-2"></i>Mis Direcciones
        </h5>
        <a href="/cliente/direcciones/crear" class="btn boton-principal">
            <i class="fas fa-plus me-2"></i>+ dirección
        </a>
    </div>

    {{#each direcciones}}
    <div class="tarjeta mb-2">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <p class="fw-bold mb-0" style="color:var(--marron-oscuro);">
                    <i class="fas fa-map-marker-alt me-2" style="color:var(--marron-medio);"></i>{{nombre}}
                </p>
                <p class="text-muted small mb-0">{{descripcion}}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/cliente/direcciones/{{_id}}/editar" class="btn btn-sm boton-secundario">Editar</a>
                <a href="/cliente/direcciones/{{_id}}/eliminar" class="btn btn-sm btn-danger">Eliminar</a>
            </div>
        </div>
    </div>
    {{else}}
    <div class="tarjeta text-center py-5">
        <i class="fas fa-map-marker-alt fa-3x mb-3" style="color: var(--crema-borde);"></i>
        <p class="text-muted">No tienes direcciones registradas aún.</p>
    </div>
    {{/each}}
</div>