<div class="container mt-4" style="max-width: 500px;">
    <h5 class="mb-4" style="color: var(--marron-oscuro);">
        <i class="fas fa-plus me-2"></i>Nueva Dirección
    </h5>
    <div class="tarjeta">
        {{> mensajes}}
        <form action="/cliente/direcciones/crear" method="POST">
            <div class="mb-3">
                <label class="form-label etiqueta">Nombre de la dirección</label>
                <input type="text" name="nombre" class="form-control campo-input"
                    placeholder="Ej: Casa, Oficina..." value="{{datos.nombre}}" required>
            </div>
            <div class="mb-4">
                <label class="form-label etiqueta">Descripción</label>
                <input type="text" name="descripcion" class="form-control campo-input"
                    placeholder="Ej: Calle 5, #23, apto 4B" value="{{datos.descripcion}}" required>
            </div>
            <div class="d-flex gap-2">
                <a href="/cliente/direcciones" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Crear dirección
                </button>
            </div>
        </form>
    </div>
</div>