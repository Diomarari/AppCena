<div class="container-fluid mt-4">
    <div class="row">
        <!-- Catálogo -->
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a href="javascript:history.back()" class="btn boton-secundario me-3">
                    <i class="fas fa-arrow-left"></i>
                </a>
                {{#if comercio.logo}}
                    <img src="/uploads/{{comercio.logo}}" style="width:45px;height:45px;border-radius:50%;object-fit:cover;margin-right:12px;">
                {{/if}}
                <h5 class="mb-0" style="color: var(--marron-oscuro);">{{comercio.nombreComercio}}</h5>
            </div>

            {{#each catalogo}}
            <h6 class="fw-bold mt-4 mb-3" style="color: var(--marron-medio); border-bottom: 2px solid var(--crema-borde); padding-bottom: 8px;">
                {{nombre}}
            </h6>
            <div class="row g-3">
                {{#each productos}}
                <div class="col-md-6">
                    <div class="tarjeta producto-card" id="card-{{_id}}">
                        <div class="d-flex gap-3">
                            {{#if foto}}
                                <img src="/uploads/{{foto}}" style="width:80px;height:80px;object-fit:cover;border-radius:10px;flex-shrink:0;">
                            {{else}}
                                <div style="width:80px;height:80px;background:var(--crema-oscuro);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    <i class="fas fa-utensils" style="color:var(--marron-medio);font-size:1.5rem;"></i>
                                </div>
                            {{/if}}
                            <div class="flex-grow-1">
                                <p class="fw-bold mb-1" style="color:var(--marron-oscuro);">{{nombre}}</p>
                                <p class="text-muted small mb-2">{{descripcion}}</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold" style="color:var(--marron-medio);">RD$ {{precio}}</span>
                                    <button class="btn btn-sm boton-principal btn-agregar"
                                        onclick="agregarAlCarrito('{{_id}}', '{{nombre}}', {{precio}})"
                                        id="btn-{{_id}}">
                                        Agregar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <div class="tarjeta text-center py-4">
                <p class="text-muted">Este comercio aún no tiene productos.</p>
            </div>
            {{/each}}
        </div>

        <!-- Carrito -->
        <div class="col-lg-4">
            <div class="tarjeta carrito-sticky">
                <h6 class="fw-bold mb-3" style="color:var(--marron-oscuro);">
                    <i class="fas fa-shopping-bag me-2"></i>Mi pedido
                </h6>
                <div id="carrito-vacio" class="text-center py-3">
                    <i class="fas fa-shopping-cart fa-2x mb-2" style="color:var(--crema-borde);"></i>
                    <p class="text-muted small">Tu pedido está vacío</p>
                </div>
                <div id="carrito-items" style="display:none;">
                    <div id="lista-carrito"></div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Subtotal</span>
                        <span id="subtotal-carrito">RD$ 0.00</span>
                    </div>
                    <form id="form-pedido" action="/cliente/confirmar-pedido" method="GET" class="mt-3">
                        <input type="hidden" name="comercioId" value="{{comercio._id}}">
                        <input type="hidden" name="productos" id="input-productos">
                        <button type="submit" class="btn boton-principal w-100">
                            Continuar <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let carrito = []

function agregarAlCarrito(id, nombre, precio) {
    const yaExiste = carrito.find(p => p.id === id)
    if (yaExiste) return

    carrito.push({ id, nombre, precio })
    document.getElementById('btn-' + id).disabled = true
    document.getElementById('btn-' + id).textContent = '✓ Agregado'
    actualizarCarrito()
}

function quitarDelCarrito(id, nombre, precio) {
    carrito = carrito.filter(p => p.id !== id)
    const btn = document.getElementById('btn-' + id)
    if (btn) {
        btn.disabled = false
        btn.textContent = 'Agregar'
    }
    actualizarCarrito()
}

function actualizarCarrito() {
    const listaEl = document.getElementById('lista-carrito')
    const vacioEl = document.getElementById('carrito-vacio')
    const itemsEl = document.getElementById('carrito-items')
    const subtotalEl = document.getElementById('subtotal-carrito')
    const inputProductos = document.getElementById('input-productos')

    if (carrito.length === 0) {
        vacioEl.style.display = 'block'
        itemsEl.style.display = 'none'
        return
    }

    vacioEl.style.display = 'none'
    itemsEl.style.display = 'block'

    let html = ''
    let subtotal = 0

    carrito.forEach(p => {
        subtotal += p.precio
        html += `
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small">${p.nombre}</span>
                <div class="d-flex align-items-center gap-2">
                    <span class="small fw-bold">RD$ ${p.precio.toFixed(2)}</span>
                    <button type="button" class="btn btn-sm btn-danger py-0 px-1"
                        onclick="quitarDelCarrito('${p.id}', '${p.nombre}', ${p.precio})"
                        style="font-size:0.7rem;">Eliminar</button>
                </div>
            </div>`
    })

    listaEl.innerHTML = html
    subtotalEl.textContent = 'RD$ ' + subtotal.toFixed(2)
    inputProductos.value = encodeURIComponent(JSON.stringify(carrito))
}
</script>