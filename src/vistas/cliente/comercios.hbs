<div class="container mt-4">
    <div class="d-flex align-items-center mb-3">
        <a href="/cliente/home" class="btn boton-secundario me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h5 class="mb-0" style="color: var(--marron-oscuro);">{{tipo.nombre}}</h5>
    </div>

    <form action="/cliente/comercios/{{tipo._id}}" method="GET" class="mb-3">
        <div class="input-group">
            <input type="text" name="buscar" class="form-control campo-input"
                placeholder="Buscar comercio por nombre..." value="{{busqueda}}">
            <button type="submit" class="btn boton-principal">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </form>

    <p class="text-muted mb-3">
        <strong>{{cantidad}}</strong> {{tipo.nombre}} disponibles
    </p>

    {{#each comercios}}
    <div class="tarjeta d-flex align-items-center justify-content-between">
        <a href="/cliente/catalogo/{{_id}}" class="d-flex align-items-center text-decoration-none flex-grow-1">
            {{#if logo}}
                <img src="/uploads/{{logo}}" alt="{{nombreComercio}}"
                    style="width:55px;height:55px;border-radius:50%;object-fit:cover;margin-right:15px;">
            {{else}}
                <div style="width:55px;height:55px;border-radius:50%;background:var(--crema-oscuro);display:flex;align-items:center;justify-content:center;margin-right:15px;">
                    <i class="fas fa-store" style="color:var(--marron-medio);"></i>
                </div>
            {{/if}}
            <span class="fw-bold" style="color: var(--marron-oscuro);">{{nombreComercio}}</span>
        </a>
        <form action="/cliente/favoritos/{{_id}}/toggle" method="POST">
            <button type="submit" class="btn btn-sm boton-texto" title="{{#if esFavorito}}Quitar de favoritos{{else}}Agregar a favoritos{{/if}}">
                <i class="{{#if esFavorito}}fas{{else}}far{{/if}} fa-heart"
                    style="color: {{#if esFavorito}}#dc3545{{else}}#aaa{{/if}}; font-size: 1.3rem;"></i>
            </button>
        </form>
    </div>
    {{else}}
    <div class="tarjeta text-center py-5">
        <i class="fas fa-search fa-3x mb-3" style="color: var(--crema-borde);"></i>
        <p class="text-muted">No se encontraron comercios.</p>
    </div>
    {{/each}}
</div>