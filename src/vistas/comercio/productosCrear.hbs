<div class="container mt-4" style="max-width:550px;">
    <h5 class="mb-4" style="color:var(--marron-oscuro);">
        <i class="fas fa-plus me-2"></i>Nuevo Producto
    </h5>
    <div class="tarjeta">
        {{> mensajes}}
        <form action="/comercio/productos/crear" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label etiqueta">Nombre del producto</label>
                <input type="text" name="nombre" class="form-control campo-input"
                    placeholder="Ej: Pizza Margherita" value="{{datos.nombre}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Descripción</label>
                <input type="text" name="descripcion" class="form-control campo-input"
                    placeholder="Breve descripción del producto"
                    value="{{datos.descripcion}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Precio (RD$)</label>
                <input type="number" name="precio" class="form-control campo-input"
                    placeholder="0.00" step="0.01" min="0"
                    value="{{datos.precio}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Categoría</label>
                <select name="categoriaId" class="form-select campo-input" required>
                    <option value="">Selecciona una categoría...</option>
                    {{#each categorias}}
                        <option value="{{_id}}">{{nombre}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label etiqueta">Foto del producto</label>
                <input type="file" name="foto" class="form-control campo-input"
                    accept="image/*" required>
            </div>
            <div class="d-flex gap-2">
                <a href="/comercio/productos" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Crear producto
                </button>
            </div>
        </form>
    </div>
</div>