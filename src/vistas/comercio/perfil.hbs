<div class="container mt-4" style="max-width:500px;">
    <h5 class="mb-4" style="color:var(--marron-oscuro);">
        <i class="fas fa-store me-2"></i>Perfil del Comercio
    </h5>
    <div class="tarjeta">
        {{> mensajes}}
        <form action="/comercio/perfil" method="POST" enctype="multipart/form-data">
            {{#if comercio.logo}}
            <div class="text-center mb-3">
                <img src="/uploads/{{comercio.logo}}"
                    style="width:80px;height:80px;border-radius:50%;object-fit:cover;">
            </div>
            {{/if}}
            <div class="mb-3">
                <label class="form-label etiqueta">
                    Logo del comercio <span class="texto-opcional">(opcional)</span>
                </label>
                <input type="file" name="logo" class="form-control campo-input" accept="image/*">
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Hora de apertura</label>
                    <input type="time" name="horaApertura" class="form-control campo-input"
                        value="{{comercio.horaApertura}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label etiqueta">Hora de cierre</label>
                    <input type="time" name="horaCierre" class="form-control campo-input"
                        value="{{comercio.horaCierre}}" required>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Teléfono</label>
                <input type="text" name="telefono" class="form-control campo-input"
                    value="{{usuarioDatos.telefono}}" required>
            </div>
            <div class="mb-4">
                <label class="form-label etiqueta">Correo</label>
                <input type="email" name="correo" class="form-control campo-input"
                    value="{{usuarioDatos.correo}}" required>
            </div>
            <div class="d-flex gap-2">
                <a href="/comercio/home" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>