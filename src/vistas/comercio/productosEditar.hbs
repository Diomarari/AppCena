<div class="container mt-4" style="max-width:550px;">
    <h5 class="mb-4" style="color:var(--marron-oscuro);">
        <i class="fas fa-edit me-2"></i>Editar Producto
    </h5>
    <div class="tarjeta">
        {{> mensajes}}
        <form action="/comercio/productos/{{producto._id}}/editar"
            method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label etiqueta">Nombre del producto</label>
                <input type="text" name="nombre" class="form-control campo-input"
                    value="{{producto.nombre}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Descripción</label>
                <input type="text" name="descripcion" class="form-control campo-input"
                    value="{{producto.descripcion}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Precio (RD$)</label>
                <input type="number" name="precio" class="form-control campo-input"
                    step="0.01" min="0" value="{{producto.precio}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label etiqueta">Categoría</label>
                <select name="categoriaId" class="form-select campo-input" required>
                    <option value="">Selecciona una categoría...</option>
                    {{#each categorias}}
                        <option value="{{_id}}"
                            {{#if (eq _id ../categoriaSeleccionada)}}selected{{/if}}>
                            {{nombre}}
                        </option>
                    {{/each}}
                </select>
            </div>
            {{#if producto.foto}}
            <div class="mb-2">
                <p class="etiqueta mb-1">Foto actual:</p>
                <img src="/uploads/{{producto.foto}}"
                    style="width:80px;height:80px;object-fit:cover;border-radius:10px;">
            </div>
            {{/if}}
            <div class="mb-4">
                <label class="form-label etiqueta">
                    Cambiar foto <span class="texto-opcional">(opcional)</span>
                </label>
                <input type="file" name="foto" class="form-control campo-input" accept="image/*">
            </div>
            <div class="d-flex gap-2">
                <a href="/comercio/productos" class="btn boton-secundario">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                <button type="submit" class="btn boton-principal">
                    <i class="fas fa-save me-2"></i>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>