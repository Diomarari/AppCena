<div class="container mt-4">
    <div class="tarjeta text-center" style="max-width:450px;margin:auto;">
        <i class="fas fa-exclamation-triangle fa-3x mb-3" style="color:#dc3545;"></i>
        <h5 class="fw-bold mb-2">¿Está seguro que desea eliminar esta categoría?</h5>
        <p class="text-muted mb-4">Se eliminará: <strong>{{categoria.nombre}}</strong></p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/comercio/categorias" class="btn boton-secundario">
                <i class="fas fa-times me-2"></i>Cancelar
            </a>
            <form action="/comercio/categorias/{{categoria._id}}/eliminar" method="POST">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-2"></i>Aceptar
                </button>
            </form>
        </div>
    </div>
</div>