<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 style="color:var(--marron-oscuro);">
            <i class="fas fa-tags me-2"></i>Mantenimiento de Categorías
        </h5>
        <a href="/comercio/categorias/crear" class="btn boton-principal">
            <i class="fas fa-plus me-2"></i>Nueva categoría
        </a>
    </div>

    <div class="tarjeta">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead style="background-color:var(--crema-oscuro);">
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Productos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each categorias}}
                    <tr>
                        <td class="fw-bold">{{nombre}}</td>
                        <td class="text-muted">{{descripcion}}</td>
                        <td>{{cantidad}}</td>
                        <td>
                            <a href="/comercio/categorias/{{_id}}/editar"
                                class="btn btn-sm boton-secundario me-1">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a href="/comercio/categorias/{{_id}}/eliminar"
                                class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No has creado categorías aún.
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>